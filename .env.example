"""
.env.example: Example environment variables file.
"""

# Dawinix API Key
DAWINIX_API_KEY=daw-sk-YOUR_API_KEY_HERE

# Optional: API base URL (defaults to https://api.dawinix.com/v1)
# DAWINIX_API_BASE_URL=https://api.dawinix.com/v1

# Optional: Request timeout in seconds
# DAWINIX_API_TIMEOUT=30

# Optional: Enable SDK logging
# DAWINIX_SDK_DEBUG=false
